# Copy this file to .env and update the values before running locally.
# Do not commit your actual .env file or service account JSON.

# Firebase web config values
# FIREBASE_API_KEY=your_api_key_here
# FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
# FIREBASE_APP_ID=your_app_id
# FIREBASE_MEASUREMENT_ID=your_measurement_id

# Optionally point to a local Firebase service account JSON file for server-side Firestore access.
# FIREBASE_SERVICE_ACCOUNT=firebase-key.json
# GOOGLE_APPLICATION_CREDENTIALS=firebase-key.json
